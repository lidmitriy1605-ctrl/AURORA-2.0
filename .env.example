# Keep the real token only in .env. Never commit it.
TELEGRAM_BOT_TOKEN=
# Set after sending /start to the bot and receiving your chat ID.
TELEGRAM_OWNER_CHAT_ID=
# Add after Eva sends /start to the bot; enables private family notifications.
TELEGRAM_EVA_CHAT_ID=
# Add only after the bot is added to the private family group. This is the group chat ID, not an invite link.
TELEGRAM_FAMILY_CHAT_ID=
